# ════════════════════════════════════════════════════════
# CervicalAI Backend — Environment Variables
# Copy to .env and fill in values
# ════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── CORS — comma-separated allowed frontend origins ────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# ── Model paths ────────────────────────────────────────
MODEL_DIR=models

# ── Kaggle (for dataset download during training) ──────
# Get from: kaggle.com → Account → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
